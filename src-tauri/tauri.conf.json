{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "雪王高速导出",
  "version": "0.1.0",
  "identifier": "cool.cnb.fucksky.xwjd.export",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "雪王高速导出客户端",
        "width": 760,
        "height": 560,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["xwjdexport"]
      }
    }
  }
}
