{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ShyExcel",
  "version": "0.2.0",
  "identifier": "com.shyexcel.app",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "ShyExcel · 数据导出",
        "width": 760,
        "height": 560,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["shyexport"]
      }
    }
  }
}
